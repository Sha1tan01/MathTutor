<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_example_step"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_step_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/blue_700"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_step_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.5"/>

    <ru.mathtutor.app.presentation.common.MathWebView
        android:id="@+id/wv_step_formula"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btn_ask_ai_example"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:text="🤖 Не понимаю этот шаг"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:background="@drawable/bg_ai_button"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone"
        style="@style/Widget.Material3.Button"/>

</LinearLayout>
