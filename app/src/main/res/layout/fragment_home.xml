<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_topbar"
            android:padding="20dp"
            android:paddingTop="40dp"
            android:orientation="vertical">

            <TextView
                android:text="∫ МатТьютор"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Высшая математика"
                android:textSize="13sp"
                android:textColor="#CCffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_blue_bg"
                app:cardElevation="0dp"
                app:strokeColor="@color/blue_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:text="Добрый день 👋"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/blue_900"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tv_progress_subtitle"
                        android:text="Продолжайте обучение"
                        android:textSize="13sp"
                        android:textColor="@color/blue_700"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:text="Прогресс"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tv_progress_percent"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/blue_700"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_bar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_bar_drawable"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Last topic card -->
            <TextView
                android:text="Последняя тема"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_last_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:text="∫"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_icon_blue"
                        android:gravity="center"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tv_last_topic_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/blue_900"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tv_last_topic_section"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/blue_200"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Nav buttons -->
            <TextView
                android:text="Навигация"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_lectures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView android:text="📚" android:textSize="28sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Лекции" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/blue_800"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView android:text="12 разделов" android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_tasks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView android:text="✏️" android:textSize="28sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Задания" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/blue_800"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView android:text="84 задачи" android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_ai_chat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView android:text="🤖" android:textSize="28sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="ИИ-чат" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/blue_800"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView android:text="Репетитор онлайн" android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView android:text="📊" android:textSize="28sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Прогресс" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/blue_800"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView android:text="Статистика" android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
